{
  "name": "@moruk/numy",
  "main": "expo-router/entry",
  "version": "1.1.7",
  "engines": {
    "node": "24.12.0"
  },
  "scripts": {
    "build:android": "eas build --platform android --profile production --local",
    "build:ios": "eas build --platform ios --profile production --local",
    "cache:clear": "rm -rf .expo/cache && watchman watch-del-all && rm -rf /tmp/metro-* /tmp/react-* 2>/dev/null || true",
    "lint:circular": "node ../../scripts/check-circular.js",
    "lint:dead-code": "bunx knip --reporter compact --no-exit-code",
    "lint:duplication": "bunx jscpd src/ app/ --ignore \"**/*.d.ts,**/__tests__/**\" --threshold 100",
    "deploy:local": "bun run killport && ../../scripts/build/ios_build_submit.sh",
    "doctor": "bun run doctor:fix",
    "doctor:fix": "npx expo install --fix && npx expo install --check",
    "fix": "bun run lint:fix && bun run format:fix && bun run doctor:fix",
    "format": "bun run format:fix",
    "format:check": "npx prettier --check . --log-level error",
    "format:fix": "npx prettier --write . --log-level error",
    "killport": "PYTHONPATH=../../ python3 -m scripts.killport",
    "lint-expo": "bun run lint:fix",
    "lint:check": "expo lint --quiet",
    "lint:fix": "expo lint --fix --quiet",
    "prepare": "husky",
    "test": "jest --passWithNoTests --silent",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint:custom": "jest --passWithNoTests --silent --bail --testPathPattern='(src/shared/__tests__/lint/|__tests__/lint/)'",
    "test:watch": "jest --watch --passWithNoTests",
    "translate": "node scripts/localization/translate-ai.js",
    "type-check": "node ../../scripts/type-check.js",
    "lint:ads": "node ../../scripts/test-ads-schema.js",
    "lint:metadata": "node ../../scripts/localization-validator.js",
    "check:circular": "bun run lint:circular",
    "check:dead-code": "bun run lint:dead-code",
    "check:duplication": "bun run lint:duplication",
    "check:native": "node ../../scripts/check-native-modules.js",
    "android": "bun run killport && expo run:android --port 2010",
    "clean": "sh -c 'rm -rf ~/Library/Developer/Xcode/DerivedData/Numy* ios/Pods ios/build android/build android/app/build' && CI=1 npx expo prebuild --clean",
    "ios": "bun run killport && expo run:ios --port 2010",
    "ios:fast": "bun run killport && USE_CCACHE=1 expo run:ios --no-install --port 2010",
    "lint": "expo lint",
    "start": "bun run killport && expo start --port 2010",
    "test:lint": "jest --passWithNoTests --silent --bail --testPathPattern='(../../shared/__tests__/lint/|__tests__/lint/)'",
    "validate": "concurrently --kill-others-on-fail -n \"TypeCheck,Lint,Format,Doctor,Test\" -c \"magenta,cyan,yellow,magenta,purple\" \"bun run type-check\" \"bun run lint\" \"bun run format\" \"bun run doctor\" \"bun run test\"",
    "validate:metadata": "node ../../scripts/localization-validator.js",
    "watchman:clean": "watchman watch-del-all"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/analytics": "^23.8.3",
    "@react-native-firebase/app": "^23.8.3",
    "@react-native-firebase/crashlytics": "^23.8.3",
    "@sentry/react-native": "~7.2.0",
    "@shopify/flash-list": "2.0.2",
    "decimal.js": "^10.6.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-battery": "~10.0.7",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-haptics": "^15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "^17.0.8",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-updates": "~29.0.16",
    "i18next": "^25.6.3",
    "mathjs": "^15.1.0",
    "react": "19.1.0",
    "react-i18next": "^16.3.5",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-google-mobile-ads": "^16.0.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1",
    "tinyglobby": "^0.2.15",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "^25.0.9",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.10",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-expo": "^10.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "js-yaml": "^4.1.0",
    "prettier": "^3.7.4",
    "react-refresh": "~0.14.2",
    "react-test-renderer": "19.1.0",
    "sharp": "^0.34.5",
    "ts-jest": "~29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "zod": "^3.24.1"
  },
  "private": true,
  "packageManager": "bun@1.3.8",
  "resolutions": {
    "react": "19.1.0",
    "react-test-renderer": "19.1.0",
    "react-native": "0.81.5",
    "@types/react": "~19.1.10"
  }
}
