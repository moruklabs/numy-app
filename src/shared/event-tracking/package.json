{
  "name": "@moruk/event-tracking",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "lint": "bun run lint:fix",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "validate": "concurrently --kill-others-on-fail -n \"TypeCheck,Lint\" -c \"magenta,cyan\" \"bun run type-check\" \"bun run lint\"",
    "clean": "rm -rf dist",
    "doctor:fix": "exit 0",
    "fix": "bun run lint:fix && bun run format:fix && bun run doctor:fix",
    "format": "bun run format:fix",
    "format:fix": "npx prettier --ignore-path ../../.prettierignore --write . --log-level error"
  },
  "dependencies": {
    "@moruk/storage": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "concurrently": "*",
    "eslint": "*",
    "prettier": "*",
    "typescript": "*"
  },
  "packageManager": "bun@1.3.8"
}
