{
  "name": "@moruk/hooks",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "lint": "bun run lint:fix",
    "lint:fix": "eslint src/ --fix",
    "type-check": "tsc --noEmit",
    "validate": "concurrently --kill-others-on-fail -n \"TypeCheck,Lint,Test\" -c \"magenta,cyan,purple\" \"bun run type-check\" \"bun run lint\" \"bun run test\"",
    "clean": "rm -rf dist",
    "test": "jest --passWithNoTests --silent",
    "doctor:fix": "exit 0",
    "fix": "bun run lint:fix && bun run format:fix && bun run doctor:fix",
    "format": "bun run format:fix",
    "format:fix": "npx prettier --ignore-path ../../.prettierignore --write . --log-level error"
  },
  "dependencies": {
    "@moruk/image": "*",
    "@moruk/logger": "*",
    "@moruk/storage": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "*",
    "@types/react": "*",
    "concurrently": "*",
    "eslint": "*",
    "jest": "*",
    "jest-expo": "*",
    "prettier": "*",
    "react": "*",
    "react-test-renderer": "*",
    "typescript": "*"
  },
  "packageManager": "bun@1.3.8"
}
