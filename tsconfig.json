{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-native",
    "allowJs": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@moruk/logger": ["./src/shared/logger"],
      "@moruk/logger/*": ["./src/shared/logger/*"],
      "@moruk/observability": ["./src/shared/logger"],
      "@moruk/observability/*": ["./src/shared/logger/*"],
      "@moruk/api": ["./src/shared/ai"],
      "@moruk/api/*": ["./src/shared/ai/*"],
      "@moruk/ai": ["./src/shared/ai"],
      "@moruk/ai/*": ["./src/shared/ai/*"],
      "@moruk/ui": ["./src/shared/ui"],
      "@moruk/ui/*": ["./src/shared/ui/*"],
      "@moruk/ui/primitives": ["./src/shared/ui"],
      "@moruk/ui/primitives/*": ["./src/shared/ui/*"],
      "@moruk/hoc": ["./src/shared/ui"],
      "@moruk/hooks": ["./src/shared/hooks"],
      "@moruk/hooks/*": ["./src/shared/hooks/*"],
      "@/*": ["./src/*"],
      "@moruk/*": ["./src/shared/*"],
      "expo-router/src/*": ["./node_modules/expo-router/build/*"]
    },
    "types": ["jest"],
    "target": "ESNext",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true
  },
  "exclude": ["node_modules", "**/node_modules/**", "android", "ios", "dist", "coverage", ".expo"],
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "**/*.d.ts",
    "types/**/*.d.ts"
  ],
  "extends": "expo/tsconfig.base"
}
